# Server
PORT=3002

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=DESIRED_OLLAMA_TIMEOUT_MS_VALUE

# Market data (Binance public API by default)
BINANCE_BASE_URL=https://api.binance.com
MARKET_SYMBOL=BTCUSDT # default symbol for market data
MARKET_TIMEOUT_MS=DESIRED_MARKET_TIMEOUT_MS_VALUE
MARKET_PRICE_TTL_MS=DESIRED_MARKET_PRICE_TTL_MS_VALUE
MARKET_KLINES_TTL_MS=DESIRED_MARKET_KLINES_TTL_MS_VALUE

# Rate limiting
ASK_RATE_LIMIT_WINDOW_MS=DESIRED_ASK_RATE_LIMIT_WINDOW_MS_VALUE
ASK_RATE_LIMIT_MAX=DESIRED_ASK_RATE_LIMIT_MAX_VALUE
